# Copy to .env and adjust. Used by server.js and worker.js.

# ─── API Server ───────────────────────────────────────────────
PORT=3010
NODE_ENV=development

# Optional: require x-api-key header on all requests
# API_KEY=your-secret-key

# ─── CORS ─────────────────────────────────────────────────────
CORS_ORIGIN=*

# ─── Redis (required for async mode and task storage) ─────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=

# ─── Proxy check ──────────────────────────────────────────────
# Timeout per proxy check in seconds (default: 3)
PROXY_HEALTHCHECK_TIMEOUT_SECONDS=3

# ─── Worker ───────────────────────────────────────────────────
# Concurrent proxy checks per worker process (default: 10)
WORKER_CONCURRENCY=10

# ─── Sync batch ───────────────────────────────────────────────
# Max proxies in one POST /check/sync request (default: 50)
SYNC_MAX_BATCH=50
